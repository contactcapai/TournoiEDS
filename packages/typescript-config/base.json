{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Base (bundler, strict)",
  "_comment": "Base extraite du tsconfig.app.json reel du front tournoi (TS strict, bundler mode). Les apps redefinissent lib/types/jsx/tsBuildInfoFile selon leur cible.",
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  }
}
