# docker/.env.example — Variables de substitution pour docker-compose.yml
# Copier en docker/.env sur le VPS et remplir les valeurs REELLES.
# Ce fichier sert UNIQUEMENT pour la stack Docker (Traefik + PG).
# Les vars applicatives backend (DATABASE_URL, JWT_SECRET, etc.) sont dans backend/.env.prod.

# --- PostgreSQL ---
# Nom logique de la base, de l'utilisateur applicatif, et mot de passe.
# Generer un mot de passe fort : openssl rand -base64 32
POSTGRES_DB=tournoi_tft
POSTGRES_USER=tournoi
POSTGRES_PASSWORD=change-me-openssl-rand-base64-32

# --- Let's Encrypt / Traefik ---
# Email de contact pour les renouvellements ACME (Brice)
LETSENCRYPT_EMAIL=bricecharley@gmail.com

# CA server Let's Encrypt :
# STAGING (a utiliser pour le PREMIER demarrage, evite les rate limits) :
LETSENCRYPT_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# PROD (a basculer APRES validation staging, cf. Task 7 / AC #10) :
# LETSENCRYPT_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
