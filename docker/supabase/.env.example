# docker/supabase/.env.example — Variables Supabase self-hosted
# Copier en docker/supabase/.env sur le VPS et remplir les VRAIES valeurs.
# Ne JAMAIS commiter ce fichier avec des valeurs reelles (AR-SEC4).
# Ce fichier (.env.example) est versionne ; docker/supabase/.env est gitignore.
#
# ─────────────────────────────────────────────────
# GENERATION DES CLES (a executer en local, une seule fois)
# ─────────────────────────────────────────────────
# JWT_SECRET :
#   openssl rand -hex 32
#
# ANON_KEY + SERVICE_ROLE_KEY (JWT signes avec JWT_SECRET, role=anon|service_role) :
#   Utiliser le generateur officiel :
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#   ou via supabase CLI : supabase gen keys --project-ref <ref> --experimental
#
# POSTGRES_PASSWORD :
#   openssl rand -base64 32
#
# TRAEFIK_BASIC_AUTH_USERS (htpasswd) :
#   htpasswd -nb <user> <password>
#   ex: admin:$apr1$...   (echapper le $ en $$ dans le fichier .env)
#
# SECRET_KEY_BASE (Realtime) :
#   openssl rand -base64 64
#
# REALTIME_ENC_KEY :
#   openssl rand -hex 16
# ─────────────────────────────────────────────────

# --- PostgreSQL Supabase ---
# MOT DE PASSE unique pour la base Supabase (DISTINCT de tournoi-tft-postgres).
# Ne jamais reutiliser le mot de passe du tournoi.
POSTGRES_PASSWORD=change-me-openssl-rand-base64-32

# --- JWT ---
# Cle secrete de signature des tokens JWT Supabase.
# TOUTES les cles derivees (ANON_KEY, SERVICE_ROLE_KEY) doivent etre regenerees
# si JWT_SECRET change. Ne jamais utiliser la valeur par defaut du repo supabase/docker.
JWT_SECRET=change-me-openssl-rand-hex-32
JWT_EXPIRY=3600

# --- Cles API Supabase (JWT signes) ---
# Generer via https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# ANON_KEY    : role=anon      (expose aux clients publics via Kong)
# SERVICE_ROLE_KEY : role=service_role (admin complet, NE JAMAIS exposer cote client)
ANON_KEY=change-me-jwt-anon-key
SERVICE_ROLE_KEY=change-me-jwt-service-role-key

# --- Acces Studio (admin Supabase) ---
# Studio n'est PAS expose via Traefik (acces SSH tunnel uniquement).
# DASHBOARD_USERNAME / DASHBOARD_PASSWORD = identifiants Kong (couche basique de Kong).
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-strong-password

# --- Basic-auth Traefik (couche de protection Kong) ---
# Format htpasswd : htpasswd -nb user password
# Les $ doivent etre echappes en $$ dans le fichier .env.
# Exemple : admin:$$apr1$$xyz$$...
TRAEFIK_BASIC_AUTH_USERS=change-me-htpasswd-output

# --- URLs publiques ---
SITE_URL=https://esportdessacres.fr
API_EXTERNAL_URL=https://supabase.esportdessacres.fr
ADDITIONAL_REDIRECT_URLS=

# --- SMTP (optionnel : emails de confirmation/reset via GoTrue) ---
# Laisser vide pour desactiver les emails (GOTRUE_MAILER_AUTOCONFIRM=true si pas de SMTP).
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Esport des Sacres

# --- Supabase Realtime ---
# Generer via openssl rand -base64 64
SECRET_KEY_BASE=change-me-openssl-rand-base64-64
# Generer via openssl rand -hex 16
REALTIME_ENC_KEY=change-me-openssl-rand-hex-16

# --- Studio ---
STUDIO_DEFAULT_ORGANIZATION=EDS
STUDIO_DEFAULT_PROJECT=vitrine

# --- Logflare / Analytics ---
# Cle interne analytics (peut rester aleatoire, non exposee publiquement).
LOGFLARE_API_KEY=change-me-logflare-api-key

# --- Feature flags ---
ENABLE_EMAIL_SIGNUP=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_AUTOCONFIRM=false
DISABLE_SIGNUP=true

# --- Image proxy ---
IMGPROXY_ENABLE_WEBP_DETECTION=true

# --- PostgREST ---
PGRST_DB_SCHEMAS=public,storage,graphql_public
