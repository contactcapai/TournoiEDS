# apps/vitrine/.env.prod.example — Variables de la vitrine en PRODUCTION
# Copier en apps/vitrine/.env.prod sur le VPS et remplir les valeurs REELLES.
# Ne JAMAIS commiter ce fichier avec des valeurs reelles (AR-SEC4).
# apps/vitrine/.env.prod est gitignore.

# ─────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL
# Note : cette variable est INLINEEE AU BUILD (pas au runtime).
# Elle est passee en --build-arg dans le Dockerfile et en build.args dans docker-compose.yml.
# La documenter ici pour reference, mais sa valeur effective est celle du build-arg.
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://esportdessacres.fr

# ─────────────────────────────────────────────────
# DATABASE_URL — Connexion Postgres Supabase (RUNTIME UNIQUEMENT)
# Pointe sur le Postgres de la stack Supabase (supabase-db), PAS sur tournoi-tft-postgres.
# host = nom du service "db" Supabase sur le reseau tournoi-net.
# Port direct 5432 (connexion directe, prepare:false deja pose cote client Drizzle).
# IMPORTANT : ne jamais prefixer NEXT_PUBLIC_ (server-only, contient des identifiants).
# Generer le mot de passe avec : openssl rand -base64 32 (meme valeur que POSTGRES_PASSWORD
# dans docker/supabase/.env — utilisateur "postgres" ou un role dedie).
# ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:change-me-postgres-password@supabase-db:5432/postgres
