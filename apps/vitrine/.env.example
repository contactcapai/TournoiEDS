# apps/vitrine — variables d'environnement (modele). Aucun secret commite (AR-SEC4).
# Copier en `.env.local` (ignore par git) et renseigner les vraies valeurs en local.
# Les variables exposees au navigateur DOIVENT etre prefixees NEXT_PUBLIC_.

# URL publique de base du site (utilisee plus tard pour SEO/metadata canoniques).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Connexion Postgres (Drizzle) — base Supabase self-hosted (Story 1.8).
# Modele de chaine, SANS secret : renseigner la vraie valeur en `.env.local` (jamais commite).
# Server-only : ne JAMAIS prefixer NEXT_PUBLIC_ (l'URL contient des identifiants).
DATABASE_URL=postgresql://user:password@host:5432/dbname
