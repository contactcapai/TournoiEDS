# node-linker=hoisted : reproduit un node_modules "plat" facon npm.
# Les apps tournoi (tournoi-web / tournoi-api) ont ete developpees et mises en
# production sous npm (resolution a plat). Le mode hoisted evite que la
# resolution stricte/symlink de pnpm ne fasse surgir des "phantom dependencies"
# (paquets utilises mais non declares) -> garde-fou non-regression de la story 1.0.
node-linker=hoisted

# Evite les avertissements de build sur des peerDeps non critiques.
strict-peer-dependencies=false
